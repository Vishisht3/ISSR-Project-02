flowchart TD
    subgraph AUDIT["Audit Log"]
        A1["Receive event from\nIndividual or\nAggregate track"] --> A2["Assemble log record:\n- timestamp\n- region_id\n- track (individual|aggregate)\n- scores (severity / crisis)\n- action taken\n- confidence score\n- event_type (if aggregate)\n- human_reviewer_id (if escalated)"]
        A2 --> A3["Append to\nimmutable audit store\n(append-only)"]
        A3 --> A4["Index by:\nregion, timestamp,\naction_type"]
    end

    subgraph HEAT["Heatmap Output"]
        A4 --> H1["Query audit log\nfor time window T"]
        H1 --> H2["Aggregate per region:\n- crisis_score_avg\n- action_count\n- escalation_count"]
        H2 --> H3["Normalise scores\nto colour scale\n(green → yellow → red)"]
        H3 --> H4["Render geo heatmap\noverlay on map tiles"]
        H4 --> H5["Annotate hotspots\nwith event_type labels"]
        H5 --> H6["Publish to\ndashboard endpoint"]
    end

    style A3 fill:#e8eaf6,stroke:#283593
    style H4 fill:#fff3e0,stroke:#e65100
    style H6 fill:#c8e6c9,stroke:#1b5e20
